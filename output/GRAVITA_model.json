  "thesis": {
    "investment_thesis": "Gravita is poised to benefit from India's circular economy push and regulatory tailwinds in battery recycling. The company's capacity doubling to 7 lakh MTPA by FY28, diversification into lithium-ion and rubber recycling, and improving domestic scrap availability provide strong growth visibility. Management's Vision 2029 targets 25%+ volume CAGR with expanding non-lead contribution create multiple re-rating catalysts.",
    "bull_case": "Capacity expansion execution drives 20%+ revenue CAGR; New verticals (lithium-ion, rubber, copper) achieve targeted margins; Domestic scrap availability improves to 60%+ reducing working capital; Non-lead contribution reaches 30% with higher margins; Global expansion accelerates with strategic acquisitions",
    "bear_case": "Capacity expansion delays due to regulatory approvals; Commodity price volatility impacts margins; Competition intensifies in lead recycling; New vertical ramp-up slower than expected; Global economic slowdown affects scrap availability",
    "key_catalysts": [
      "Completion of 1.25 lakh MTPA lead capacity by Q4 FY26",
      "Lithium-ion battery recycling plant commissioning at Mundra",
      "Copper recycling plant setup at Mandvi, Gujarat (29,400 MTPA)",
      "RMIL acquisition synergies and integration completion"
    ],
    "key_risks": [
      "Regulatory delays in capacity expansion approvals",
      "Raw material scrap availability fluctuations",
      "Commodity price volatility affecting margins",
      "New vertical execution and scaling risks"
    ],
