  "risk_items": [
    {
      "category": "Regulatory",
      "factor": "Environmental compliance and licensing delays",
      "description": "Capacity expansion projects dependent on state-level consent-to-operate licenses, with recent delays in Gujarat affecting timeline.",
      "mitigation": "Proactive engagement with regulatory authorities and maintaining buffer timelines for project completion",
      "probability": "M",
      "impact": "H",
      "rating": "MEDIUM"
    },
    {
      "category": "Market",
      "factor": "Commodity price volatility",
      "description": "Aluminum and plastic recycling exposed to price fluctuations due to lack of effective hedging mechanisms unlike lead operations.",
      "mitigation": "Gradual introduction of aluminum hedging on MCX and focus on value-added products with stable margins",
      "probability": "H",
      "impact": "M",
      "rating": "MEDIUM"
    },
    {
      "category": "Operational",
      "factor": "Raw material scrap availability",
      "description": "Dependency on consistent scrap supply from domestic and international sources, with geopolitical tensions affecting import logistics.",
      "mitigation": "Diversified supplier network across 70+ countries and increasing domestic scrap sourcing to 60%+",
      "probability": "M",
      "impact": "H",
      "rating": "MEDIUM"
    },
    {
      "category": "Competition",
      "factor": "Market share erosion from organized players",
      "description": "Entry of large corporations and battery OEMs into recycling space could intensify competition and margin pressure.",
      "mitigation": "Strong brand relationships with OEMs, technical expertise, and focus on value-added products differentiation",
      "probability": "M",
      "impact": "M",
      "rating": "LOW"
    },
    {
      "category": "Execution",
      "factor": "New vertical scaling challenges",
      "description": "Lithium-ion, rubber, and copper recycling ventures require different technical expertise and market development than core lead business.",
      "mitigation": "Pilot projects, strategic partnerships, and phased capacity additions with continuous monitoring of returns",
      "probability": "H",
      "impact": "M",
      "rating": "MEDIUM"
    },
    {
      "category": "Financial",
      "factor": "High capital expenditure execution risk",
      "description": "Rs 1,225cr capex plan through FY28 requires efficient capital allocation and project management across multiple geographies.",
      "mitigation": "Disciplined ROIC benchmark of 25% for new investments and focus on brownfield expansion to reduce risks",
      "probability": "M",
      "impact": "H",
      "rating": "MEDIUM"
    },
